PORT=8765
RENDER_MODE=sync

# local keeps uploaded files under data/jobs for MVP development.
# Use r2 or s3 in production with direct browser uploads.
STORAGE_PROVIDER=local

# S3/R2 compatible storage.
STORAGE_BUCKET=
STORAGE_REGION=auto
STORAGE_ENDPOINT_URL=
STORAGE_PUBLIC_BASE_URL=
STORAGE_PREFIX=uploads
STORAGE_PRESIGN_SECONDS=900

# Optional local transcript.
WHISPER_MODEL=base
WHISPER_DEVICE=cpu

# Optional AI clip selection. If no key is set, the app falls back to local heuristic scoring.
# Values: auto, openai, gemini, off
AI_SUGGESTION_PROVIDER=auto
AI_SUGGESTION_TEMPERATURE=0.45
AI_SUGGESTION_TIMEOUT=45

# OpenAI suggestion provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Gemini suggestion provider. GOOGLE_API_KEY is also accepted.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1